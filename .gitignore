# =========================
# Python cache & compiled files
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual environment
# =========================
venv/
env/
ENV/
.venv/

# =========================
# Environment variables
# =========================
.env
.env.*

# =========================
# Django specific
# =========================
*.log
db.sqlite3
db.sqlite3-journal

# =========================
# Static & media files
# =========================
staticfiles/
media/

# =========================
# Migrations (optional)
# =========================
